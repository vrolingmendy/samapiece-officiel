# Copiez ce fichier en « .env » à la racine de samapiece_php (même dossier que config.php).
# Le fichier .env n’est pas versionné (voir .gitignore).
#
# En ligne : définissez plutôt ces variables dans le panneau d’hébergement (Apache/Nginx, PaaS).

SAMAPIECE_SMTP_HOST=goo-bridge.com
SAMAPIECE_SMTP_PORT=465
SAMAPIECE_SMTP_ENCRYPTION=ssl
SAMAPIECE_SMTP_USER=samapiece-noreply@goo-bridge.com
SAMAPIECE_SMTP_PASSWORD=
SAMAPIECE_EMAIL_FROM=samapiece-noreply@goo-bridge.com

# Si la connexion SSL échoue en local (certificat), essayez : SAMAPIECE_SMTP_SSL_VERIFY=0
